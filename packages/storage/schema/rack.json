{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registry.rackjs.com/schemas/rack.json",
  "title": "Rack Configuration",
  "description": "Schema for a Rack project manifest (rack.json) — tracks installed registries and project settings",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "registryIdentifier": {
      "type": "string",
      "oneOf": [
        {
          "pattern": "^@[a-z0-9](?:[a-z0-9_-]*[a-z0-9])?/[a-z0-9-]+(?:/[a-z0-9-]+)*(?:@(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?)?(?::(js|ts))?$",
          "description": "Full format: @namespace/path (optional @version, optional :language)"
        },
        {
          "pattern": "^[a-z0-9-]+(?:/[a-z0-9-]+)*(?:@(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?)?(?::(js|ts))?$",
          "description": "Shorthand: path (optional @version, optional :language, resolves to @rack/path)"
        }
      ]
    }
  },
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Project name"
    },
    "language": {
      "type": "string",
      "enum": ["js", "ts"],
      "description": "Active language variant for installed registries (js or ts)"
    },
    "template": {
      "type": "string",
      "minLength": 1,
      "description": "Preset used to initialize the project (e.g. presets/node)"
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/registryIdentifier" },
      "description": "Installed registry identifiers"
    }
  },
  "required": ["name"]
}
