{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registry.rackjs.com/schemas/preset.json",
  "title": "Preset Configuration",
  "description": "Schema for a preset (preset.json) — a curated bundle of registries installed together",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "registryIdentifier": {
      "type": "string",
      "oneOf": [
        {
          "pattern": "^@[a-z0-9](?:[a-z0-9_-]*[a-z0-9])?/[a-z0-9-]+(?:/[a-z0-9-]+)*(?:@[a-zA-Z0-9._+-]+)?(?::(js|ts))?$",
          "description": "Full format: @namespace/path (optional @version, optional :language)"
        },
        {
          "pattern": "^[a-z0-9-]+(?:/[a-z0-9-]+)*(?:@[a-zA-Z0-9._+-]+)?(?::(js|ts))?$",
          "description": "Shorthand: path (optional @version, optional :language, resolves to @rack/path)"
        }
      ]
    }
  },
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Preset name (kebab-case)"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
      "description": "Semantic version (semver)"
    },
    "description": {
      "type": "string",
      "description": "Short human-readable summary"
    },
    "author": {
      "type": "string",
      "description": "Author name and (optionally) contact"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Free-form keywords for discovery"
    },
    "registries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/registryIdentifier" },
      "description": "Registries to install (in declared order)"
    }
  },
  "required": ["name", "version", "registries"]
}
