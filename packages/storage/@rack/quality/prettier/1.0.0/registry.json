{
  "$schema": "https://rackjs.com/schema/registry-item.json",
  "name": "prettier",
  "namespace": "@rack",
  "version": "1.0.0",
  "type": "registry:quality",
  "priority": 6,
  "description": "Prettier code formatter configuration",
  "tags": ["prettier", "formatting", "code-quality"],
  "registryDependencies": [
    "@rack/quality/lint-staged"
  ],
  "devDependencies": {
    "prettier": "^3.0.3"
  },
  "files": [
    {
      "target": ".prettierrc",
      "type": "registry:config",
      "content": "{\n  \"tabWidth\": 2,\n  \"semi\": false,\n  \"singleQuote\": true,\n  \"trailingComma\": \"none\"\n}"
    },
    {
      "target": ".lintstagedrc",
      "type": "registry:config",
      "path": "./templates/.lintstagedrc",
      "mergeStrategy": {
        "type": "builtin",
        "strategy": "json"
      }
    }
  ]
}
