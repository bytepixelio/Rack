{
  "$schema": "https://rackjs.com/schema/registry-item.json",
  "name": "lint-staged",
  "namespace": "@rack",
  "version": "1.0.0",
  "type": "registry:quality",
  "priority": 6,
  "description": "Lint-staged integration for Git pre-commit hooks",
  "tags": ["lint-staged", "git-hooks", "code-quality"],
  "registryDependencies": [
    "@rack/quality/husky"
  ],
  "devDependencies": {
    "lint-staged": "^14.0.1"
  },
  "files": [
    {
      "target": ".lintstagedrc",
      "type": "registry:config",
      "content": "{}",
      "mergeStrategy": {
        "type": "builtin",
        "strategy": "json"
      }
    },
    {
      "target": ".husky/pre-commit",
      "type": "registry:script",
      "path": "./templates/.husky/pre-commit",
      "executable": true
    }
  ]
}
