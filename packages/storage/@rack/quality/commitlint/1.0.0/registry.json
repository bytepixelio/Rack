{
  "$schema": "https://registry.rackjs.com/schemas/registry-item.json",
  "name": "commitlint",
  "namespace": "@rack",
  "version": "1.0.0",
  "type": "registry:quality",
  "priority": 6,
  "description": "Commitlint and Commitizen configuration for conventional commits",
  "tags": ["git", "commitlint", "commitizen", "code-quality"],
  "registryDependencies": ["@rack/quality/husky"],
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "commitizen": "^4.3.1",
    "cz-customizable": "^7.5.4"
  },
  "scripts": {
    "commit": "npx git-cz"
  },
  "files": [
    {
      "target": ".commitlintrc",
      "type": "registry:config",
      "path": "./templates/.commitlintrc"
    },
    {
      "target": ".cz-config.cjs",
      "type": "registry:config",
      "path": "./templates/.cz-config.cjs"
    },
    {
      "target": ".czrc",
      "type": "registry:config",
      "content": "{\n  \"path\": \"node_modules/cz-customizable\"\n}",
      "mergeStrategy": {
        "type": "builtin",
        "strategy": "json"
      }
    },
    {
      "target": ".husky/commit-msg",
      "type": "registry:script",
      "path": "./templates/.husky/commit-msg",
      "executable": true
    }
  ]
}
