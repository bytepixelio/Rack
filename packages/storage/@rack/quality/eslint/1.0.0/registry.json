{
  "$schema": "https://registry.rackjs.com/schemas/registry-item.json",
  "name": "eslint",
  "namespace": "@rack",
  "version": "1.0.0",
  "type": "registry:quality",
  "priority": 6,
  "description": "ESLint configuration with TypeScript and Prettier support",
  "tags": ["eslint", "linting", "code-quality"],
  "registryDependencies": [
    "@rack/quality/prettier",
    "@rack/quality/lint-staged"
  ],
  "devDependencies": {
    "eslint": "^8.50.0",
    "@typescript-eslint/eslint-plugin": "^6.7.2",
    "@typescript-eslint/parser": "^6.7.2",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0"
  },
  "files": [
    {
      "target": ".eslintrc.js",
      "type": "registry:config",
      "path": "./templates/.eslintrc.js"
    },
    {
      "target": ".lintstagedrc",
      "type": "registry:config",
      "path": "./templates/.lintstagedrc",
      "mergeStrategy": {
        "type": "builtin",
        "strategy": "json"
      }
    },
    {
      "target": ".gitignore",
      "type": "registry:config",
      "path": "./templates/.gitignore"
    }
  ]
}
