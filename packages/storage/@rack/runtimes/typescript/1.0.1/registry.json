{
  "$schema": "https://registry.rackjs.com/schemas/registry-item.json",
  "name": "typescript",
  "namespace": "@rack",
  "version": "1.0.1",
  "type": "registry:runtime",
  "priority": 1,
  "description": "TypeScript runtime with entry file and execution scripts",
  "tags": ["runtime", "language", "typescript"],
  "registryDependencies": [
    "@rack/runtimes/node",
    "@rack/build/typescript"
  ],
  "devDependencies": {
    "tsx": "^4.21.0"
  },
  "scripts": {
    "start": "npx tsx ./src/index.ts"
  },
  "files": [
    {
      "target": "src/index.ts",
      "type": "registry:entry",
      "path": "./templates/src/index.ts"
    }
  ]
}
