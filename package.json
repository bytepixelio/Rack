{
  "name": "rack",
  "version": "1.0.0",
  "description": "Based on the Registry architecture, scaffolds can be freely combined to quickly start projects",
  "private": true,
  "license": "MIT",
  "author": "2046",
  "homepage": "https://rackjs.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bytepixelio/Rack.git"
  },
  "bugs": {
    "url": "https://github.com/bytepixelio/Rack/issues"
  },
  "type": "module",
  "scripts": {
    "commit": "npx git-cz",
    "prepare": "husky install",
    "preinstall": "npx only-allow pnpm",
    "dev": "TURBO_LOG_VERBOSITY=0 turbo dev",
    "test": "TURBO_LOG_VERBOSITY=0 turbo test",
    "lint": "TURBO_LOG_VERBOSITY=0 turbo lint",
    "build": "TURBO_LOG_VERBOSITY=0 turbo build",
    "clean": "turbo clean && rm -rf node_modules",
    "test:e2e": "TURBO_LOG_VERBOSITY=0 turbo test:e2e",
    "docs": "TURBO_LOG_VERBOSITY=0 turbo docs:build && TURBO_LOG_VERBOSITY=0 turbo docs:preview",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@eslint/js": "9.33.0",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "commitizen": "4.3.1",
    "cz-customizable": "7.5.4",
    "eslint": "9.33.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "only-allow": "1.2.2",
    "prettier": "3.8.3",
    "typescript": "5.9.2"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    },
    "cz-customizable": {
      "config": ".cz-config.cjs"
    }
  },
  "engines": {
    "node": ">=22.10.0",
    "pnpm": ">=10.8.0"
  },
  "packageManager": "pnpm@10.14.0",
  "dependencies": {
    "turbo": "2.9.9"
  },
  "pnpm": {
    "overrides": {
      "lodash@<4.18.0": "^4.18.0",
      "flatted@<3.4.2": "^3.4.2",
      "js-yaml@<4.1.1": "^4.1.1",
      "read-yaml-file@<2.0.1": "^2.1.0",
      "tmp@<0.2.4": "^0.2.4",
      "glob@<10.5.0": "^10.5.0",
      "minimatch@<3.1.4": "^3.1.4",
      "minimatch@>=9 <9.0.7": "^9.0.7",
      "picomatch@<2.3.2": "^2.3.2",
      "picomatch@>=4 <4.0.4": "^4.0.4",
      "brace-expansion@<1.1.13": "^1.1.13",
      "brace-expansion@>=2 <2.0.3": "^2.0.3",
      "vite@<5.4.21": "^5.4.21",
      "vite@>=6 <6.4.2": "^6.4.2",
      "vite@>=7 <7.3.2": "^7.3.2",
      "postcss@<8.5.10": "^8.5.10",
      "esbuild@<0.25.0": "^0.25.0"
    }
  }
}
