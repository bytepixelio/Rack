# Server Configuration
# PORT / HOST are read by the Node process. In Docker, PORT inside the
# container is pinned to 8080 by docker-compose.yml; use HOST_PORT below
# to change the host-side port the container is published on.
PORT=8080
HOST=0.0.0.0

# Docker host-side port (only used by docker-compose.yml). Default 18080
# — intentionally off the common-collision 8080. Override if you need
# something else.
# HOST_PORT=18080

# Storage Configuration
STORAGE_ROOT=../../packages/storage
# SCHEMA_DIR defaults to <STORAGE_ROOT>/schema when unset. Docker uses
# /app/schema (baked into the image) so schema upgrades don't require
# clearing the data volume.
# SCHEMA_DIR=../../packages/storage/schema
# STORAGE_BACKEND=local

# R2 Configuration (required when STORAGE_BACKEND=r2)
# R2_BUCKET_NAME=rack-registry
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-access-key-id
# R2_SECRET_ACCESS_KEY=your-secret-access-key

# Authentication Configuration
# Local layout: repo-root config/auth.json. Resolved relative to the
# server cwd (apps/registry-server), so the path is ../../config/...
# Docker compose overrides this to the container path (config/auth.json
# under /app) via its own env mapping — do NOT change the value here
# to the container path, that breaks pnpm dev.
AUTH_CONFIG_PATH=../../config/auth.json
# ADMIN_TOKEN=your-secret-admin-token

# Webhook Configuration
# Local layout: server-local apps/registry-server/config/webhooks.json,
# i.e. just config/webhooks.json relative to the server cwd. (This is
# already the code default — listed here as documentation.) Docker
# compose mounts the same filename at /app/config/webhooks.json.
WEBHOOK_CONFIG_PATH=config/webhooks.json

# Logging Configuration
LOG_LEVEL=info
NODE_ENV=development

# Reverse-proxy configuration (Nginx / ALB / Cloudflare Tunnel)
# Set when the server runs behind a proxy so the rate limiter keys per
# real client IP from `X-Forwarded-For` instead of the proxy IP.
# Accepts `true`, `false`, or a positive hop count (e.g. `1`, `2`).
# TRUST_PROXY=true
