{
  "name": "@rack/registry-server",
  "version": "1.0.0",
  "private": true,
  "description": "Rack Registry Static File Server",
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run --coverage --silent"
  },
  "dependencies": {
    "ajv": "8.17.1",
    "tar": "7.5.13",
    "pino": "^9.5.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "ajv-formats": "3.0.1",
    "mime-types": "3.0.1",
    "pino-pretty": "^13.0.0",
    "prom-client": "15.1.3",
    "fastify-plugin": "^5.0.1",
    "fastify-metrics": "12.1.0",
    "@fastify/caching": "9.0.3",
    "@fastify/compress": "^8.0.1",
    "@fastify/multipart": "10.0.0",
    "@fastify/rate-limit": "^10.1.1",
    "@aws-sdk/client-s3": "3.1033.0"
  },
  "devDependencies": {
    "tsx": "4.20.6",
    "tsup": "8.5.1",
    "vitest": "2.1.4",
    "form-data": "4.0.4",
    "typescript": "5.9.2",
    "@types/tar": "7.0.87",
    "@types/node": "20.19.17",
    "@types/form-data": "2.5.2",
    "@types/mime-types": "3.0.1",
    "@rack/auth-core": "workspace:*",
    "@vitest/coverage-v8": "2.1.4"
  }
}
